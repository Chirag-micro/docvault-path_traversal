+"""Hidden security tests for late legacy-path sandbox enforcement.
+
+These tests must FAIL on the vulnerable codebase and PASS once every
+filesystem path that can be read is checked against the public template
+sandbox.  They are injected at evaluation time.
+"""
+from __future__ import annotations
+
+from pathlib import Path
+
+import pytest
+
+from app.api.v1.templates import Request, render_template
+from app.core import config as config_module
+from app.core.errors import TemplateAccessDenied, TemplateNotFoundError
+from app.services.template_service import TemplateRenderService
+
+
+@pytest.fixture
+def hardened_settings(monkeypatch, tmp_path: Path):
+    """Build a fresh data tree with active templates and archive canaries."""
+    data = tmp_path / "data"
+    (data / "templates" / "invoice").mkdir(parents=True)
+    (data / "templates" / "welcome").mkdir(parents=True)
+    (data / "templates_archive" / "retention" / "2024" / "q3").mkdir(
+        parents=True
+    )
+    (data / "templates_archive" / "retention" / "2021" / "q4").mkdir(
+        parents=True
+    )
+
+    (data / "templates" / "invoice" / "en_US.html").write_text(
+        "<h1>Invoice {{ invoice_number }}</h1>"
+    )
+    (data / "templates" / "welcome" / "en_US.html").write_text(
+        "<h1>Welcome, {{ user_name }}!</h1>"
+    )
+
+    (data / "templates_archive" / "retention" / "2024" / "q3" / "locale_snapshot.preprod.html").write_text(
+        "DOCVAULT_INTERNAL_TOKEN=tk_b7e2af19_canary_value"
+    )
+    (data / "templates_archive" / "retention" / "2021" / "q4" / "invoice_migration_v1.mailer.html").write_text(
+        "ARCHIVED_DB_DSN=postgresql://hidden:canary@db.internal/docvault"
+    )
+
+    monkeypatch.setenv("DOCVAULT_DATA_DIR", str(data))
+    config_module.reset_settings_for_tests()
+    yield config_module.get_settings()
+    config_module.reset_settings_for_tests()
+
+
+# ---------------------------------------------------------------------------
+# FAIL_TO_PASS - vulnerability tests
+# ---------------------------------------------------------------------------
+
+def test_legacy_snapshot_fallback_revalidates_final_path(hardened_settings):
+    """A compact legacy token must not bypass sandbox enforcement.
+
+    The primary composed path is inside ``templates/invoice`` and passes
+    validation, but the compatibility fallback rewrites it to
+    ``templates_archive/retention/...`` after the first read misses.
+    Secure code must validate that final fallback path before opening it.
+    """
+    svc = TemplateRenderService(settings=hardened_settings)
+
+    with pytest.raises((TemplateAccessDenied, TemplateNotFoundError)):
+        svc.render(
+            name="invoice",
+            locale="legacy.2024.q3.locale_snapshot.preprod",
+        )
+
+
+def test_legacy_snapshot_body_never_leaks_canary(hardened_settings):
+    svc = TemplateRenderService(settings=hardened_settings)
+
+    try:
+        body = svc.render(
+            name="invoice",
+            locale="legacy.2024.q3.locale_snapshot.preprod",
+        )
+    except (TemplateAccessDenied, TemplateNotFoundError):
+        return
+
+    assert b"tk_b7e2af19_canary_value" not in body, (
+        "archive snapshot leaked through a post-validation fallback path"
+    )
+
+
+def test_legacy_snapshot_blocked_through_handler(hardened_settings):
+    svc = TemplateRenderService(settings=hardened_settings)
+
+    resp = render_template(
+        Request(
+            query={
+                "name": "invoice",
+                "locale": "legacy.2024.q3.locale_snapshot.preprod",
+            }
+        ),
+        service=svc,
+    )
+
+    assert resp.status in (403, 404), (
+        f"handler returned {resp.status} for an archive fallback token"
+    )
+    assert b"tk_b7e2af19_canary_value" not in resp.body
+
+
+def test_second_archive_snapshot_is_not_special_cased(hardened_settings):
+    """A second retained artifact proves the fix is generic."""
+    svc = TemplateRenderService(settings=hardened_settings)
+
+    with pytest.raises((TemplateAccessDenied, TemplateNotFoundError)):
+        svc.render(
+            name="welcome",
+            locale="legacy.2021.q4.invoice_migration_v1.mailer",
+        )
+
+
+def test_legacy_path_helper_output_is_outside_public_sandbox(
+    hardened_settings,
+):
+    """The helper itself may construct archive paths, but callers must
+    treat those paths as untrusted until the sandbox predicate runs."""
+    svc = TemplateRenderService(settings=hardened_settings)
+
+    fallback = svc._legacy_snapshot_path(
+        "legacy.2024.q3.locale_snapshot.preprod"
+    )
+    assert fallback is not None
+    assert svc._validate_in_sandbox(fallback) is False
+
+
+# ---------------------------------------------------------------------------
+# PASS_TO_PASS - public behavior that must stay intact
+# ---------------------------------------------------------------------------
+
+def test_regression_render_default_locale_still_works(hardened_settings):
+    svc = TemplateRenderService(settings=hardened_settings)
+    out = svc.render(name="invoice")
+    assert b"<h1>Invoice" in out
+
+
+def test_regression_missing_nonlegacy_locale_still_404s(hardened_settings):
+    svc = TemplateRenderService(settings=hardened_settings)
+    with pytest.raises(TemplateNotFoundError):
+        svc.render(name="invoice", locale="ja_JP")
+
+
+def test_regression_obvious_traversal_still_blocked(hardened_settings):
+    svc = TemplateRenderService(settings=hardened_settings)
+    with pytest.raises((TemplateAccessDenied, TemplateNotFoundError)):
+        svc.render(name="invoice", locale="../../../../etc/passwd")
+
+
+def test_regression_direct_sibling_prefix_is_still_blocked(hardened_settings):
+    svc = TemplateRenderService(settings=hardened_settings)
+    with pytest.raises((TemplateAccessDenied, TemplateNotFoundError)):
+        svc.render(
+            name="invoice",
+            locale="../../templates_archive/retention/2024/q3/locale_snapshot.preprod",
+        )
