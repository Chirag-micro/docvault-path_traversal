+"""Hidden security tests for the template render sandbox.
+
+These tests must FAIL on the vulnerable codebase and PASS once the
+sandbox boundary check is fixed.  They are not part of the public
+regression suite — they are injected at evaluation time.
+"""
+from __future__ import annotations
+
+import os
+from pathlib import Path
+
+import pytest
+
+from app.api.v1.templates import Request, render_template
+from app.core import config as config_module
+from app.core.errors import TemplateAccessDenied, TemplateNotFoundError
+from app.services.template_service import TemplateRenderService
+
+
+@pytest.fixture
+def hardened_settings(monkeypatch, tmp_path: Path):
+    """Build a fresh data tree with a known archive secret."""
+    data = tmp_path / "data"
+    (data / "templates" / "invoice").mkdir(parents=True)
+    (data / "templates" / "welcome").mkdir(parents=True)
+    (data / "templates_archive").mkdir(parents=True)
+
+    # Canonical templates so the regression path keeps working
+    (data / "templates" / "invoice" / "en_US.html").write_text(
+        "<h1>Invoice {{ invoice_number }}</h1>"
+    )
+    (data / "templates" / "welcome" / "en_US.html").write_text(
+        "<h1>Welcome, {{ user_name }}!</h1>"
+    )
+
+    # The forbidden archive contents — these must never reach the
+    # render endpoint regardless of what the caller does.
+    (data / "templates_archive" / "internal_secret.html").write_text(
+        "DOCVAULT_INTERNAL_TOKEN=tk_b7e2af19_canary_value"
+    )
+    (data / "templates_archive" / "legacy_invoice.html").write_text(
+        "ARCHIVED_DB_DSN=postgresql://hidden:canary@db.internal/docvault"
+    )
+
+    monkeypatch.setenv("DOCVAULT_DATA_DIR", str(data))
+    config_module.reset_settings_for_tests()
+    yield config_module.get_settings()
+    config_module.reset_settings_for_tests()
+
+
+# ---------------------------------------------------------------------------
+# FAIL_TO_PASS — vulnerability tests
+# ---------------------------------------------------------------------------
+
+def test_sibling_prefix_traversal_blocked_at_service_layer(hardened_settings):
+    """Sibling directories sharing a textual prefix with the sandbox root
+    must NOT be reachable through the render service.
+
+    On the vulnerable codebase the sandbox check uses a plain
+    ``startswith`` comparison against ``/.../templates`` (no trailing
+    separator) and therefore accepts ``/.../templates_archive/...``.
+    The service must raise :class:`TemplateAccessDenied` (or, at worst,
+    :class:`TemplateNotFoundError` if the file does not exist) — never
+    return the archive content.
+    """
+    svc = TemplateRenderService(settings=hardened_settings)
+    with pytest.raises((TemplateAccessDenied, TemplateNotFoundError)):
+        svc.render(
+            name="invoice",
+            locale="../../templates_archive/internal_secret",
+        )
+
+
+def test_sibling_prefix_traversal_does_not_leak_archive_secret(
+    hardened_settings,
+):
+    """Even if the underlying file lookup somehow succeeds, the canary
+    string from the archive must never appear in the response body."""
+    svc = TemplateRenderService(settings=hardened_settings)
+    try:
+        body = svc.render(
+            name="invoice",
+            locale="../../templates_archive/internal_secret",
+        )
+    except (TemplateAccessDenied, TemplateNotFoundError):
+        return  # secure path
+    assert b"tk_b7e2af19_canary_value" not in body, (
+        "archive secret leaked through the render service"
+    )
+
+
+def test_sibling_prefix_traversal_blocked_through_handler(hardened_settings):
+    """The HTTP-shaped handler must surface the sandbox violation as a
+    4xx response, not a 200 with archive content."""
+    svc = TemplateRenderService(settings=hardened_settings)
+    resp = render_template(
+        Request(
+            query={
+                "name": "invoice",
+                "locale": "../../templates_archive/internal_secret",
+            }
+        ),
+        service=svc,
+    )
+    assert resp.status in (400, 403, 404), (
+        f"handler returned {resp.status} for a sandbox-escape input"
+    )
+    assert b"tk_b7e2af19_canary_value" not in resp.body
+
+
+def test_sibling_prefix_traversal_with_legacy_archive_file(hardened_settings):
+    """A second sibling-archive payload must also be unreachable —
+    proves the fix is generic and not keyed on a single filename."""
+    svc = TemplateRenderService(settings=hardened_settings)
+    with pytest.raises((TemplateAccessDenied, TemplateNotFoundError)):
+        svc.render(
+            name="welcome",
+            locale="../../templates_archive/legacy_invoice",
+        )
+
+
+def test_validator_rejects_sibling_prefix_directly(hardened_settings):
+    """Direct unit test of the sandbox predicate.
+
+    A path that lives in a sibling directory whose name merely starts
+    with the sandbox root's basename must NOT be considered inside the
+    sandbox.  This is the underlying defect the fix must address; an
+    agent that only patches the public ``render`` method without
+    correcting the predicate will fail this assertion.
+    """
+    svc = TemplateRenderService(settings=hardened_settings)
+    sibling = os.path.join(
+        hardened_settings.archive_dir, "internal_secret.html"
+    )
+    assert svc._validate_in_sandbox(sibling) is False, (
+        "_validate_in_sandbox must reject paths in sibling directories "
+        "that share a textual prefix with the sandbox root"
+    )
+
+
+def test_validator_accepts_legitimate_template_path(hardened_settings):
+    """The fix must not be over-broad — legitimate paths under the
+    real templates directory must still be accepted."""
+    svc = TemplateRenderService(settings=hardened_settings)
+    legit = os.path.join(
+        hardened_settings.templates_dir, "invoice", "en_US.html"
+    )
+    assert svc._validate_in_sandbox(legit) is True
+
+
+# ---------------------------------------------------------------------------
+# PASS_TO_PASS — regression tests that already passed and must keep passing
+# (these exercise the existing test files; we re-import them to make
+# sure the agent does not silently delete or weaken them.)
+# ---------------------------------------------------------------------------
+
+def test_regression_render_default_locale_still_works(hardened_settings):
+    svc = TemplateRenderService(settings=hardened_settings)
+    out = svc.render(name="invoice")
+    assert b"<h1>Invoice" in out
+
+
+def test_regression_obvious_traversal_still_blocked(hardened_settings):
+    svc = TemplateRenderService(settings=hardened_settings)
+    with pytest.raises((TemplateAccessDenied, TemplateNotFoundError)):
+        svc.render(name="invoice", locale="../../../../etc/passwd")
